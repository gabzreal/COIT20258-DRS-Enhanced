<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.DisasterReportController"
            style="-fx-background-color:#F4F6F8;">

    <top>

        <HBox style="-fx-background-color:#D32F2F;"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="🚨 Emergency Incident Report"
                   style="
                        -fx-text-fill:white;
                        -fx-font-size:28;
                        -fx-font-weight:bold;
                   "/>

        </HBox>

    </top>

    <center>

        <HBox spacing="25">

            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <!-- LEFT SIDE -->

            <VBox spacing="15"
                  prefWidth="700">

                <Label text="Incident Details"
                       style="
                            -fx-font-size:22;
                            -fx-font-weight:bold;
                       "/>

                <VBox spacing="15">

                    <Label text="Select Disaster Type"
                           style="
                -fx-font-size:18;
                -fx-font-weight:bold;
           "/>

                    <HBox spacing="10">

                        <Button fx:id="fireButton"
                                text="🔥 FIRE"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectFire"
                                style="
                    -fx-background-color:#E53935;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>

                        <Button fx:id="floodButton"
                                text="🌊 FLOOD"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectFlood"
                                style="
                    -fx-background-color:#1E88E5;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>

                        <Button fx:id="stormButton"
                                text="⛈ STORM"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectStorm"
                                style="
                    -fx-background-color:#8E24AA;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>

                    </HBox>

                    <HBox spacing="10">

                        <Button fx:id="collapseButton"
                                text="🏢 COLLAPSE"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectCollapse"
                                style="
                    -fx-background-color:#6D4C41;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>

                        <Button fx:id="outageButton"
                                text="⚡ OUTAGE"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectOutage"
                                style="
                    -fx-background-color:#FB8C00;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>

                        <Button fx:id="otherButton"
                                text="🚧 OTHER"
                                prefWidth="160"
                                prefHeight="70"
                                onAction="#selectOther"
                                style="
                    -fx-background-color:#546E7A;
                    -fx-text-fill:white;
                    -fx-font-size:16;
                    -fx-font-weight:bold;
                    -fx-background-radius:15;
                    -fx-cursor:hand;
                "/>
                        

                    </HBox>
                    <Label fx:id="selectedTypeLabel"
                           text="No disaster type selected"
                           style="
            -fx-font-size:15;
            -fx-font-weight:bold;
            -fx-text-fill:#D32F2F;
       "/>
                    

                </VBox>

                <VBox spacing="8">
                    <Label text="Severity Level (Optional)"
                           style="
            -fx-font-size:16;
            -fx-font-weight:bold;
       "/>

                    <HBox spacing="15">

                        <!-- MINOR -->

                        <Button text="🟢 MINOR"
                                onAction="#selectMinor"
                                prefWidth="180"
                                prefHeight="60"
                                style="
                -fx-background-color:#E8F5E9;
                -fx-text-fill:#2E7D32;
                -fx-font-size:18;
                -fx-font-weight:bold;
                -fx-background-radius:15;
                -fx-border-radius:15;
                -fx-border-color:#4CAF50;
                -fx-border-width:2;
            "/>

                        <!-- MODERATE -->

                        <Button text="🟡 MODERATE"
                                onAction="#selectModerate"
                                prefWidth="180"
                                prefHeight="60"
                                style="
                -fx-background-color:#FFF8E1;
                -fx-text-fill:#F57F17;
                -fx-font-size:18;
                -fx-font-weight:bold;
                -fx-background-radius:15;
                -fx-border-radius:15;
                -fx-border-color:#FFC107;
                -fx-border-width:2;
            "/>

                        <!-- SEVERE -->

                        <Button text="🔴 SEVERE"
                                onAction="#selectSevere"
                                prefWidth="180"
                                prefHeight="60"
                                style="
                -fx-background-color:#FFEBEE;
                -fx-text-fill:#C62828;
                -fx-font-size:18;
                -fx-font-weight:bold;
                -fx-background-radius:15;
                -fx-border-radius:15;
                -fx-border-color:#F44336;
                -fx-border-width:2;
            "/>

                    </HBox>

                    <Label fx:id="selectedSeverityLabel"
                           text="No severity selected"
                           style="
            -fx-font-size:14;
            -fx-font-weight:bold;
            -fx-text-fill:#666666;
       "/>

                    <Label text="📍 Location (Required)"
                           style="
            -fx-font-size:16;
            -fx-font-weight:bold;
       "/>

            

                    <TextField fx:id="locationField"
                               promptText="Location"
                               text="Melbourne CBD"/>

                    <Button text="📡 Use My Current Location"
                            prefWidth="250"
                            onAction="#handleLiveLocation"
                            style="
                -fx-background-color:#2E7D32;
                -fx-text-fill:white;
                -fx-font-weight:bold;
            "/>

                    <Label text="Always allow location access during emergencies for faster response and accurate dispatch."
                           wrapText="true"
                           style="
                -fx-font-size:11;
                -fx-text-fill:#666666;
           "/>

                </VBox>

                <TextField fx:id="gpsField"
                           text="-37.8136, 144.9631"
                           promptText="GPS Coordinates"/>

                <TextField fx:id="landmarkField"
                           promptText="Nearby Landmark (e.g. Flinders Street Station - Optional)"/>

                <TextArea fx:id="descriptionArea"
                          prefHeight="180"
                          promptText="Describe the emergency situation...(Optional)"/>

                <Button text="📷 Upload Evidence (Optional)"
                        prefWidth="200"
                        onAction="#handleUpload"/>

                <Button text="🚨 Submit Report"
                        prefHeight="50"
                        style="
                            -fx-background-color:#D32F2F;
                            -fx-text-fill:white;
                            -fx-font-size:16;
                            -fx-font-weight:bold;
                        "
                        onAction="#handleSubmit"/>

            </VBox>

            <!-- RIGHT SIDE -->

            <VBox spacing="20"
                  prefWidth="350">

                <!-- FEATURE 1 PREVIEW -->

                <VBox spacing="10"
                      style="
                            -fx-background-color:white;
                            -fx-padding:20;
                            -fx-background-radius:15;
                            -fx-border-radius:15;
                            -fx-border-color:#E0E0E0;
                      ">

                    <Label text="🧠 Smart Severity Analysis"
                           style="
                                -fx-font-size:18;
                                -fx-font-weight:bold;
                           "/>

                    <Label text="Severity Score:"/>

                    <VBox spacing="8">

                        <Label text="Severity Level"
                               style="
                -fx-font-size:14;
                -fx-text-fill:#666666;
           "/>

                        <Label fx:id="severityLabel"
                               text="Waiting for report..."
                               style="
                -fx-font-size:22;
                -fx-font-weight:bold;
                -fx-text-fill:#D32F2F;
           "/>

                        <Label fx:id="severityStatusLabel"
                               text="Awaiting analysis"
                               style="
                -fx-font-size:13;
                -fx-text-fill:#666666;
           "/>

                    </VBox>

                </VBox>

                <!-- FEATURE 2 PREVIEW -->

                <VBox spacing="10"
                      style="
                            -fx-background-color:white;
                            -fx-padding:20;
                            -fx-background-radius:15;
                            -fx-border-radius:15;
                            -fx-border-color:#E0E0E0;
                      ">

                    <Label text="🏢 Infrastructure Impact"
                           style="
                                -fx-font-size:18;
                                -fx-font-weight:bold;
                           "/>

                    <Label fx:id="impactLabel"
                           wrapText="true"
                           style="
            -fx-font-size:14;
            -fx-font-weight:bold;
       "/>

                </VBox>

                <!-- SAFETY -->

                <VBox fx:id="severityCard"
                      spacing="10"
                      style="
            -fx-background-color:white;
            -fx-padding:20;
            -fx-background-radius:15;
            -fx-border-radius:15;
            -fx-border-color:#E0E0E0;
      ">

                    <Label text="⚠ Safety Reminder"
                           style="
                                -fx-font-size:18;
                                -fx-font-weight:bold;
                           "/>

                    <Label fx:id="safetyLabel"
                           text="If lives are immediately at risk, call Triple Zero (000)."
                           wrapText="true"/>

                </VBox>

            </VBox>

        </HBox>

    </center>

    <bottom>

        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#ECEFF1;">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Button text="⬅ Back"
                    onAction="#handleBack"/>

        </HBox>

    </bottom>

</BorderPane>