<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Author: Krishna Kakani | 12279867 -->

<AnchorPane prefHeight="720.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #111827);">

    <children>

        <SplitPane dividerPositions="0.42"
                   prefHeight="720.0"
                   prefWidth="1280.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.topAnchor="0.0">

            <items>

                <AnchorPane style="-fx-background-color: linear-gradient(to bottom right, #4a0000, #120000);">

                    <children>

                        <VBox alignment="TOP_LEFT"
                              layoutX="45.0"
                              layoutY="90.0"
                              spacing="22.0">

                            <padding>
                                <Insets top="20"
                                        right="20"
                                        bottom="20"
                                        left="20"/>
                            </padding>

                            <Label text="DRS Enhanced"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 40px;
                                          -fx-font-weight: bold;" />

                            <Label text="Emergency Response System"
                                   style="-fx-text-fill: #d1d5db;
                                          -fx-font-size: 20px;
                                          -fx-font-weight: bold;" />

                            <Label text="Real-Time Disaster Coordination Platform"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 15px;" />

                            <Region prefHeight="25.0" />

                            <Label text="✔ Emergency Services Active"
                                   style="-fx-text-fill: #22c55e;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: bold;" />

                            <Label text="✔ Secure Communication Enabled"
                                   style="-fx-text-fill: #22c55e;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: bold;" />

                            <Label text="✔ Disaster Monitoring Online"
                                   style="-fx-text-fill: #22c55e;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: bold;" />

                            <Label text="✔ Hospital Coordination Active"
                                   style="-fx-text-fill: #22c55e;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: bold;" />

                            <Label text="✔ Multi-Department Dispatch Enabled"
                                   style="-fx-text-fill: #22c55e;
                                          -fx-font-size: 15px;
                                          -fx-font-weight: bold;" />

                        </VBox>

                    </children>

                </AnchorPane>

                <AnchorPane style="-fx-background-color: #f8fafc;">

                    <children>

                        <VBox alignment="CENTER"
                              layoutX="110.0"
                              layoutY="140.0"
                              prefWidth="420.0"
                              spacing="22.0">

                            <padding>
                                <Insets top="20"
                                        right="20"
                                        bottom="20"
                                        left="20"/>
                            </padding>

                            <Label text="User Authentication"
                                   style="-fx-font-size: 34px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #111827;" />

                            <Label text="Sign in to access emergency operations"
                                   style="-fx-font-size: 15px;
                                          -fx-text-fill: #6b7280;" />

                            <Region prefHeight="10.0" />

                            <TextField fx:id="txtUsername"
                                       prefHeight="48.0"
                                       prefWidth="320.0"
                                       promptText="Enter Username"
                                       style="-fx-background-color: white;
                                              -fx-background-radius: 10;
                                              -fx-border-color: #d1d5db;
                                              -fx-border-radius: 10;
                                              -fx-font-size: 14px;
                                              -fx-padding: 0 0 0 12;" />

                            <PasswordField fx:id="txtPassword"
                                           prefHeight="48.0"
                                           prefWidth="320.0"
                                           promptText="Enter Password"
                                           style="-fx-background-color: white;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #d1d5db;
                                                  -fx-border-radius: 10;
                                                  -fx-font-size: 14px;
                                                  -fx-padding: 0 0 0 12;" />

                            <Region prefHeight="5.0" />

                            <Button fx:id="btnLogin"
                                    mnemonicParsing="false"
                                    onAction="#handleLogin"
                                    prefHeight="48.0"
                                    prefWidth="320.0"
                                    text="LOGIN"
                                    style="-fx-background-color: #b30000;
                                           -fx-text-fill: white;
                                           -fx-font-size: 15px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;" />

                            <Button fx:id="btnClear"
                                    mnemonicParsing="false"
                                    onAction="#handleClear"
                                    prefHeight="48.0"
                                    prefWidth="320.0"
                                    text="CLEAR"
                                    style="-fx-background-color: #374151;
                                           -fx-text-fill: white;
                                           -fx-font-size: 15px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;" />

                            <Region prefHeight="10.0" />

                            <Label fx:id="lblStatus"
                                   text="System Ready"
                                   style="-fx-text-fill: #16a34a;
                                          -fx-font-size: 14px;
                                          -fx-font-weight: bold;" />

                        </VBox>

                    </children>

                </AnchorPane>

            </items>

        </SplitPane>

    </children>

</AnchorPane>
