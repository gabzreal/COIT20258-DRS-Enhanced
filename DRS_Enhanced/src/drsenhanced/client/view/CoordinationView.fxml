<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.CoordinationController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #111827);">

    <children>

        <Label layoutX="40.0"
               layoutY="25.0"
               text="Emergency Coordination Center"
               style="-fx-text-fill: white;
                      -fx-font-size: 30px;
                      -fx-font-weight: bold;" />

       

        <VBox layoutX="40.0"
              layoutY="90.0"
              prefWidth="420.0"
              spacing="15.0"
              style="-fx-background-color: #1f2937;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Incident Coordination"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;" />

            <Label text="Incident"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbIncident"
                      promptText="Select Incident" />
            <Label text="Priority Level"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbPriority"
                      promptText="Select Priority" />

            <Label text="Department"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbDepartment"
                      promptText="Select Department" />

            <Label text="Resource"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbResource"
                      promptText="Select Resource" />

            <Label text="Incident Status"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbStatus"
                      promptText="Select Status" />

            <Label text="Coordination Notes"
                   style="-fx-text-fill: white;" />

            <TextArea fx:id="txtNotes"
                      prefHeight="120.0"
                      promptText="Enter coordination updates..." />
            

            <Button fx:id="btnAssignResource"
                    text="Assign Resource"
                    onAction="#handleAssignResource"
                    style="-fx-background-color: #b30000;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;" />

            <Button fx:id="btnUpdateStatus"
                    text="Update Status"
                    onAction="#handleUpdateStatus"
                    style="-fx-background-color: #2563eb;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;" />

            <Button fx:id="btnBack"
                    text="Back to Dashboard"
                    onAction="#handleBack"
                    style="-fx-background-color: #047857;
                           -fx-text-fill: white;" />

        </VBox>

     

        <VBox layoutX="500.0"
              layoutY="90.0"
              prefWidth="720.0"
              prefHeight="560.0"
              spacing="10.0"
              style="-fx-background-color: #1f2937;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Response Coordination Log"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;" />

            <TableView fx:id="tblCoordinationLog"
                       prefHeight="500.0">

                <columns>

                    <TableColumn fx:id="colIncident"
                                 text="Incident"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colDepartment"
                                 text="Department"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colPriority"
                                 text="Priority"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colStatus"
                                 text="Status"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colTimestamp"
                                 text="Timestamp"
                                 prefWidth="140"/>

                </columns>

            </TableView>
            <VBox layoutX="1030.0"
                  layoutY="90.0"
                  prefWidth="220.0"
                  prefHeight="560.0"
                  spacing="12.0"
                  style="-fx-background-color: #1f2937;
             -fx-background-radius: 12;
             -fx-padding: 15;">

                <Label text="🚒 Resources"
                       style="-fx-text-fill:white;
                  -fx-font-size:20px;
                  -fx-font-weight:bold;" />

                <VBox style="-fx-background-color:#991b1b;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                    <Label text="Fire Rescue Victoria"
                           style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                    <Label text="12 Units Available"
                           style="-fx-text-fill:white;" />
                </VBox>

                <VBox style="-fx-background-color:#1d4ed8;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                    <Label text="Victoria Police"
                           style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                    <Label text="8 Patrol Units"
                           style="-fx-text-fill:white;" />
                </VBox>

                <VBox style="-fx-background-color:#047857;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                    <Label text="Ambulance Victoria"
                           style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                    <Label text="15 Ambulances"
                           style="-fx-text-fill:white;" />
                </VBox>

                <VBox style="-fx-background-color:#ca8a04;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                    <Label text="Victoria SES"
                           style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                    <Label text="6 Teams Available"
                           style="-fx-text-fill:white;" />
                </VBox>

            </VBox>
        </VBox>

    </children>

</AnchorPane>