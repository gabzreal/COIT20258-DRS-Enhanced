<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.DepartmentAvailabilityController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #111827);">

    <children>

        <Label layoutX="40.0"
               layoutY="25.0"
               text="Department Operations Center"
               style="-fx-text-fill: white;
                      -fx-font-size: 30px;
                      -fx-font-weight: bold;" />

        <!-- LEFT PANEL -->

        <VBox layoutX="40.0"
              layoutY="90.0"
              prefWidth="400.0"
              spacing="15.0"
              style="-fx-background-color: #1f2937;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Department Status Update"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;" />

            <Label text="Department"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbDepartment"
                      promptText="Select Department" />
            <Label text="Personnel Available"
                   style="-fx-text-fill: white;" />

            <TextField fx:id="txtPersonnel"
                       promptText="Enter Personnel Count" />

            <Label text="Availability Status"
                   style="-fx-text-fill: white;" />

            <ComboBox fx:id="cmbStatus"
                      promptText="Select Status" />

            <Label text="Available Units"
                   style="-fx-text-fill: white;" />
            <Label text="Operational Vehicles"
                   style="-fx-text-fill: white;" />

            <TextField fx:id="txtVehicles"
                       promptText="Enter Vehicle Count" />

            <TextField fx:id="txtAvailableUnits"
                       promptText="Enter Available Units" />

            <Button fx:id="btnUpdateAvailability"
                    text="Update Availability"
                    onAction="#handleUpdateAvailability"
                    style="-fx-background-color: #b30000;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;" />

            <Button fx:id="btnRefresh"
                    text="Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: #374151;
                           -fx-text-fill: white;" />

            <Button fx:id="btnBack"
                    text="Back to Dashboard"
                    onAction="#handleBack"
                    style="-fx-background-color: #047857;
                           -fx-text-fill: white;" />

        </VBox>

       

        <VBox layoutX="480.0"
              layoutY="90.0"
              prefWidth="520.0"
              prefHeight="560.0"
              spacing="10.0"
              style="-fx-background-color: #1f2937;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Department Availability Overview"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;" />
            <HBox spacing="15">

                <VBox prefWidth="150"
                      style="-fx-background-color:#1d4ed8;
                 -fx-background-radius:10;
                 -fx-padding:12;">

                    <Label text="Departments"
                           style="-fx-text-fill:white;" />

                    <Label text="12"
                           style="-fx-text-fill:white;
                      -fx-font-size:30px;
                      -fx-font-weight:bold;" />

                </VBox>

                <VBox prefWidth="150"
                      style="-fx-background-color:#047857;
                 -fx-background-radius:10;
                 -fx-padding:12;">

                    <Label text="Available Units"
                           style="-fx-text-fill:white;" />

                    <Label text="41"
                           style="-fx-text-fill:white;
                      -fx-font-size:30px;
                      -fx-font-weight:bold;" />

                </VBox>

                <VBox prefWidth="150"
                      style="-fx-background-color:#dc2626;
                 -fx-background-radius:10;
                 -fx-padding:12;">

                    <Label text="Active Incidents"
                           style="-fx-text-fill:white;" />

                    <Label text="18"
                           style="-fx-text-fill:white;
                      -fx-font-size:30px;
                      -fx-font-weight:bold;" />

                </VBox>

            </HBox>
            <Label text="Department Status Records"
                   style="-fx-text-fill:white;
              -fx-font-size:18px;
              -fx-font-weight:bold;" />

            <TableView fx:id="tblDepartments"
                       prefHeight="380.0">

                <columns>

                    <TableColumn fx:id="colDepartment"
                                 text="Department"
                                 prefWidth="160.0"/>

                    <TableColumn fx:id="colStatus"
                                 text="Status"
                                 prefWidth="100.0"/>

                    <TableColumn fx:id="colUnits"
                                 text="Units"
                                 prefWidth="90.0"/>

                    <TableColumn fx:id="colUpdated"
                                 text="Updated"
                                 prefWidth="100.0"/>
                </columns>

            </TableView>

        </VBox>
        <VBox layoutX="1020.0"
              layoutY="90.0"
              prefWidth="220.0"
              prefHeight="560.0"
              spacing="12.0"
              style="-fx-background-color: #1f2937;
             -fx-background-radius: 12;
             -fx-padding: 15;">

            <Label text="🚑 Live Department Status"
                   style="-fx-text-fill:white;
                  -fx-font-size:18px;
                  -fx-font-weight:bold;" />

            <!-- Fire Rescue -->

            <VBox style="-fx-background-color:#991b1b;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                <Label text="Fire Rescue Victoria"
                       style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                <Label text="12 Units Available"
                       style="-fx-text-fill:white;" />

            </VBox>

            <!-- Police -->

            <VBox style="-fx-background-color:#1d4ed8;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                <Label text="Victoria Police"
                       style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                <Label text="8 Patrol Units"
                       style="-fx-text-fill:white;" />

            </VBox>

            <!-- Ambulance -->

            <VBox style="-fx-background-color:#047857;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                <Label text="Ambulance Victoria"
                       style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                <Label text="15 Ambulances"
                       style="-fx-text-fill:white;" />

            </VBox>

            <!-- SES -->

            <VBox style="-fx-background-color:#ca8a04;
                  -fx-background-radius:10;
                  -fx-padding:12;">

                <Label text="Victoria SES"
                       style="-fx-text-fill:white;
                      -fx-font-weight:bold;" />

                <Label text="6 Response Teams"
                       style="-fx-text-fill:white;" />

            </VBox>

        </VBox>

    </children>

</AnchorPane>