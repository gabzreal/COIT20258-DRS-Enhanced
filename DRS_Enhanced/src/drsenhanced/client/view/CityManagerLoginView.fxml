<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.CityManagerLoginController"
            style="-fx-background-color:#F4F6F8;">

    <top>

        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#D32F2F;">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="🏛 City Manager Login"
                   style="
                        -fx-text-fill:white;
                        -fx-font-size:26;
                        -fx-font-weight:bold;
                   "/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⬅ Back"
                    onAction="#handleBack"
                    prefWidth="100"/>

        </HBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="20">

            <VBox spacing="15"
                  prefWidth="400"
                  maxWidth="400"
                  style="
                        -fx-background-color:white;
                        -fx-padding:30;
                        -fx-background-radius:12;
                  ">

                <Label text="Manager Authentication"
                       style="
                            -fx-font-size:22;
                            -fx-font-weight:bold;
                       "/>

                <Label text="Manager ID"/>

                <TextField fx:id="managerIdField"
                           promptText="Enter Manager ID"/>

                <Label text="Password"/>

                <PasswordField fx:id="passwordField"
                               promptText="Enter Password"/>

                <Button text="Login"
                        onAction="#handleLogin"
                        prefHeight="45"
                        maxWidth="9999"
                        style="
                            -fx-background-color:#D32F2F;
                            -fx-text-fill:white;
                            -fx-font-weight:bold;
                        "/>

                <Label fx:id="messageLabel"
                       style="
                            -fx-text-fill:red;
                            -fx-font-weight:bold;
                       "/>

            </VBox>

        </VBox>

    </center>

</BorderPane>
