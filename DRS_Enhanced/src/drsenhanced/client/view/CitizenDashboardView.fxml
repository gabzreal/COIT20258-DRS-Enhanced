<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.CitizenDashboardController"
            style="-fx-background-color:#F4F6F8;">

    <!-- HEADER -->

    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="20"
              style="-fx-background-color:#1976D2;">

            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="👤 Citizen Dashboard"
                   style="
                        -fx-text-fill:white;
                        -fx-font-size:28;
                        -fx-font-weight:bold;
                   "/>

        </HBox>

    </top>

    <!-- CONTENT -->

    <center>

        <GridPane hgap="20" vgap="20">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <!-- MY REPORTS -->

            <VBox GridPane.rowIndex="0"
                  GridPane.columnIndex="0"
                  spacing="10"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:20;
                    -fx-background-radius:10;
                  ">

                <Label text="📄 My Disaster Reports"
                       style="
                            -fx-font-size:20;
                            -fx-font-weight:bold;
                       "/>

                <ListView fx:id="reportList"
                          prefHeight="250"/>

            </VBox>

            <!-- NOTIFICATIONS -->

            <VBox GridPane.rowIndex="0"
                  GridPane.columnIndex="1"
                  spacing="10"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:20;
                    -fx-background-radius:10;
                  ">

                <Label text="📢 Emergency Notifications"
                       style="
                            -fx-font-size:20;
                            -fx-font-weight:bold;
                       "/>

                <ListView fx:id="notificationList"
                          prefHeight="250"/>

            </VBox>

            <!-- STATUS TRACKER -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="0"
                  spacing="10"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:20;
                    -fx-background-radius:10;
                  ">

                <Label text="🚒 Response Status Timeline"
                       style="
                            -fx-font-size:20;
                            -fx-font-weight:bold;
                       "/>

                <Label text="✔ Report Submitted"/>

                <Label text="✔ Incident Assessed"/>

                <Label text="✔ Emergency Services Dispatched"/>

                <Label text="⏳ Resolution In Progress"/>

            </VBox>

            <!-- SHELTER CARD -->

            <VBox GridPane.rowIndex="1"
                  GridPane.columnIndex="1"
                  spacing="10"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:20;
                    -fx-background-radius:10;
                  ">

                <Label text="🏠 Nearest Emergency Shelter"
                       style="
                            -fx-font-size:20;
                            -fx-font-weight:bold;
                       "/>

                <Label text="Melbourne Town Hall Shelter"/>

                <Label text="Capacity: 120 / 200"/>

                <Label text="Distance: 1.8 km"/>

                <Button text="View Directions"
                        prefWidth="180"
                        style="
                            -fx-background-color:#2E7D32;
                            -fx-text-fill:white;
                            -fx-font-weight:bold;
                        "/>

            </VBox>

        </GridPane>

    </center>

    <!-- FOOTER -->

    <bottom>

        <HBox alignment="CENTER_RIGHT"
              spacing="10">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Button text="Logout"
                    onAction="#handleLogout"/>

        </HBox>

    </bottom>

</BorderPane>