<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.DashboardController"
            prefWidth="1400"
            prefHeight="850"
            style="-fx-background-color:#F4F6F8;">
    <top>

        <VBox>

            <!-- HEADER -->

            <HBox spacing="20"
                  alignment="CENTER"
                  style="-fx-background-color:#C62828;">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="🚨 Disaster Response System"
                       style="-fx-text-fill:white;
                              -fx-font-size:30;
                              -fx-font-weight:bold;"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <VBox spacing="25">

            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- SUBTITLE -->

            <VBox spacing="10"
                  alignment="CENTER">

                <Label text="Welcome to Victoria's Emergency Response Platform"
                       style="
                -fx-font-size:30;
                -fx-font-weight:bold;
                -fx-text-fill:#263238;
           "/>

                <Label text="Real-time disaster reporting, coordination and emergency response across Melbourne"
                       wrapText="true"
                       style="
                -fx-font-size:16;
                -fx-text-fill:#607D8B;
           "/>

            </VBox>

            <!-- MAIN ACTION BUTTONS -->

            <HBox spacing="25"
                  alignment="CENTER">

                <Button text="👤 Continue as Citizen"
                        prefWidth="260"
                        prefHeight="70"
                        onAction="#handleCitizen"
                        style="
                            -fx-background-color:#1976D2;
                            -fx-text-fill:white;
                            -fx-font-size:16;
                            -fx-font-weight:bold;
                            -fx-background-radius:10;
                            -fx-cursor:hand;
                        "/>

                <Button text="🎯 Continue as City Manager"
                        prefWidth="260"
                        prefHeight="70"
                        onAction="#handleManager"
                        style="
                            -fx-background-color:#2E7D32;
                            -fx-text-fill:white;
                            -fx-font-size:16;
                            -fx-font-weight:bold;
                            -fx-background-radius:10;
                            -fx-cursor:hand;
                        "/>

                <Button text="🚒 Continue as Emergency Worker"
                        prefWidth="280"
                        prefHeight="70"
                        onAction="#handleWorker"
                        style="
                            -fx-background-color:#EF6C00;
                            -fx-text-fill:white;
                            -fx-font-size:16;
                            -fx-font-weight:bold;
                            -fx-background-radius:10;
                            -fx-cursor:hand;
                        "/>

            </HBox>

            <!-- LIVE SYSTEM STATUS -->

            <HBox spacing="20">

                <VBox prefWidth="250"
                      spacing="10"
                      style="
                          -fx-background-color:white;
                          -fx-background-radius:10;
                          -fx-padding:20;
                          -fx-border-color:#E0E0E0;
                          -fx-border-radius:10;
                      ">

                    <Label text="ACTIVE INCIDENTS"
                           style="-fx-font-weight:bold;
                                  -fx-font-size:14;"/>

                    <Label text="12"
                           style="-fx-font-size:36;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#C62828;"/>

                </VBox>

                <VBox prefWidth="250"
                      spacing="10"
                      style="
                          -fx-background-color:white;
                          -fx-background-radius:10;
                          -fx-padding:20;
                          -fx-border-color:#E0E0E0;
                          -fx-border-radius:10;
                      ">

                    <Label text="CRITICAL INCIDENTS"
                           style="-fx-font-weight:bold;
                                  -fx-font-size:14;"/>

                    <Label text="3"
                           style="-fx-font-size:36;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#D84315;"/>

                </VBox>

                <VBox prefWidth="250"
                      spacing="10"
                      style="
                          -fx-background-color:white;
                          -fx-background-radius:10;
                          -fx-padding:20;
                          -fx-border-color:#E0E0E0;
                          -fx-border-radius:10;
                      ">

                    <Label text="RESPONSES TODAY"
                           style="-fx-font-weight:bold;
                                  -fx-font-size:14;"/>

                    <Label text="27"
                           style="-fx-font-size:36;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#2E7D32;"/>

                </VBox>

            </HBox>

            <!-- ACTIVE ALERTS -->

            <VBox spacing="10"
                  VBox.vgrow="ALWAYS"
                  style="
                      -fx-background-color:white;
                      -fx-background-radius:10;
                      -fx-padding:20;
                      -fx-border-color:#E0E0E0;
                      -fx-border-radius:10;
                  ">

                <Label text="📢 Active Alerts"
                       style="-fx-font-size:20;
                              -fx-font-weight:bold;"/>

                <ListView fx:id="alertsList"
                          prefHeight="250"/>

            </VBox>

        </VBox>

    </center>

    <bottom>

        <HBox alignment="CENTER_RIGHT"
              style="-fx-background-color:#ECEFF1;">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="DRS Enhanced v1.0"
                   style="-fx-text-fill:#616161;"/>

        </HBox>

    </bottom>

</BorderPane>