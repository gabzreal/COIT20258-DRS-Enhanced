<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>



<AnchorPane prefHeight="720.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #111827);">

    <children>

     

        <VBox layoutX="0.0"
              layoutY="0.0"
              prefWidth="260.0"
              prefHeight="720.0"
              spacing="18.0"
              style="-fx-background-color: linear-gradient(to bottom, #3b0000, #120000);
                     -fx-border-color: #7f1d1d;
                     -fx-border-width: 0 2 0 0;">

            <padding>
                <Insets top="35.0"
                        left="20.0"
                        right="20.0"
                        bottom="20.0"/>
            </padding>

            <Label text="DRS Enhanced"
                   style="-fx-text-fill: white;
                          -fx-font-size: 30px;
                          -fx-font-weight: bold;" />

            <Label text="Emergency Response System"
                   style="-fx-text-fill: #d1d5db;
                          -fx-font-size: 16px;
                          -fx-font-weight: bold;" />

            <Region prefHeight="20.0" />

            <Button text="Dashboard"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    style="-fx-background-color: #b30000;
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;" />

            <Button text="Disaster Reports"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#openDisasterReport"
                    style="-fx-background-color: #1f2937;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;" />

            <Button text="Department Availability"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#openDepartmentAvailability"
                    style="-fx-background-color: #1f2937;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;" />

            <Button text="Evacuation &amp; Shelter"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#openEvacuationShelter"
                    style="-fx-background-color: #1f2937;
               -fx-text-fill: white;
               -fx-font-size: 14px;
               -fx-background-radius: 8;" />

            <Button text="Coordination Center"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#openCoordinationCenter"
                    style="-fx-background-color: #1f2937;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 8;" />

            <Button text="Refresh Dashboard"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#refreshDashboard"
                    style="-fx-background-color: #047857;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;" />

            <Button text="Logout"
                    prefWidth="210.0"
                    prefHeight="42.0"
                    onAction="#handleLogout"
                    style="-fx-background-color: #991b1b;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;" />

            <Region prefHeight="60.0" />

            <Label text="✔ Emergency Services Active"
                   style="-fx-text-fill: #22c55e;
                          -fx-font-size: 14px;
                          -fx-font-weight: bold;" />

            <Label text="✔ Secure Communication Enabled"
                   style="-fx-text-fill: #22c55e;
                          -fx-font-size: 14px;
                          -fx-font-weight: bold;" />

            <Label text="✔ Disaster Monitoring Online"
                   style="-fx-text-fill: #22c55e;
                          -fx-font-size: 14px;
                          -fx-font-weight: bold;" />

        </VBox>



        <VBox layoutX="290.0"
              layoutY="30.0"
              spacing="20.0">

           

            <HBox prefWidth="950.0"
                  alignment="CENTER_LEFT">

                <Label text="Emergency Operations Dashboard"
                       style="-fx-text-fill: white;
                      -fx-font-size: 34px;
                      -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="lblDateTime"
                       text="Date Time"
                       style="-fx-text-fill: #22c55e;
                      -fx-font-size: 16px;
                      -fx-font-weight: bold;" />

            </HBox>

           

            <Label text="Real-Time Disaster Coordination and Monitoring"
                   style="-fx-text-fill: #d1d5db;
              -fx-font-size: 16px;" />

            <!-- SYSTEM STATUS BANNER -->

            <HBox prefWidth="1200.0"
                  style="-fx-background-color: #065f46;
             -fx-background-radius: 10;
             -fx-padding: 10;">

                <Label fx:id="lblSystemStatus"
                       text="🟢 SYSTEM STATUS: NORMAL OPERATIONS"
                       style="-fx-text-fill: white;
                  -fx-font-size: 16px;
                  -fx-font-weight: bold;" />

            </HBox>

            <!-- KPI CARDS -->

            <HBox spacing="22.0">

                <!-- ACTIVE INCIDENTS -->

                <VBox prefWidth="220.0"
                      prefHeight="130.0"
                      spacing="12.0"
                      style="-fx-background-color: linear-gradient(to bottom right, #b30000, #7f0000);
                 -fx-background-radius: 15;
                 -fx-padding: 18;">

                    <Label text="🚨 Active Incidents"
                           style="-fx-text-fill: white;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;" />

                    <Label fx:id="activeIncidentsLabel"
                           text="0"
                           style="-fx-text-fill: white;
                      -fx-font-size: 42px;
                      -fx-font-weight: bold;" />

                    <Label text="+2 in last hour"
                           style="-fx-text-fill: #fca5a5;
                      -fx-font-size: 12px;
                      -fx-font-weight: bold;" />

                </VBox>

                <!-- CRITICAL CASES -->

                <VBox prefWidth="220.0"
                      prefHeight="130.0"
                      spacing="12.0"
                      style="-fx-background-color: linear-gradient(to bottom right, #dc2626, #7f1d1d);
                 -fx-background-radius: 15;
                 -fx-padding: 18;">

                    <Label text="⚠ Critical Cases"
                           style="-fx-text-fill: white;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;" />

                    <Label fx:id="criticalCasesLabel"
                           text="0"
                           style="-fx-text-fill: white;
                      -fx-font-size: 42px;
                      -fx-font-weight: bold;" />

                    <Label text="1 requiring evacuation"
                           style="-fx-text-fill: #fecaca;
                      -fx-font-size: 12px;
                      -fx-font-weight: bold;" />

                </VBox>
             

                <VBox prefWidth="220.0"
                      prefHeight="130.0"
                      spacing="12.0"
                      style="-fx-background-color: linear-gradient(to bottom right, #047857, #064e3b);
                             -fx-background-radius: 15;
                             -fx-padding: 18;">

                    <Label text="🏢 Available Departments"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 18px;
                                  -fx-font-weight: bold;" />

                    <Label fx:id="availableDepartmentsLabel"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 42px;
                                  -fx-font-weight: bold;" />

                    <Label text="100% operational"
                           style="-fx-text-fill: #bbf7d0;
              -fx-font-size: 12px;
              -fx-font-weight: bold;" />
                </VBox>

           
                <VBox prefWidth="220.0"
                      prefHeight="130.0"
                      spacing="12.0"
                      style="-fx-background-color: linear-gradient(to bottom right, #1d4ed8, #1e3a8a);
                             -fx-background-radius: 15;
                             -fx-padding: 18;">

                    <Label text="🏠 Shelter Capacity"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 18px;
                                  -fx-font-weight: bold;" />

                    <Label fx:id="shelterCapacityLabel"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 42px;
                                  -fx-font-weight: bold;" />
                    <Label text="65% available"
                           style="-fx-text-fill: #bfdbfe;
              -fx-font-size: 12px;
              -fx-font-weight: bold;" />
                    
                </VBox>

            </HBox>
            <HBox spacing="20.0">

                <VBox prefWidth="450.0"
                      prefHeight="280.0"
                      spacing="10.0"
                      style="-fx-background-color: #1f2937;
                 -fx-background-radius: 12;
                 -fx-padding: 15;">

                    <Label text="🚨 Live Incident Feed"
                           style="-fx-text-fill: white;
                      -fx-font-size: 20px;
                      -fx-font-weight: bold;" />

                    <TextArea fx:id="incidentFeedArea"
                              prefHeight="220.0"
                              editable="false"
                              wrapText="true" />

                </VBox>

                <VBox prefWidth="500.0"
                      prefHeight="280.0"
                      spacing="10.0"
                      style="-fx-background-color: #1f2937;
                 -fx-background-radius: 12;
                 -fx-padding: 15;">

                    <Label text="📋 Recent Emergency Activity"
                           style="-fx-text-fill: white;
                      -fx-font-size: 20px;
                      -fx-font-weight: bold;" />

                    <TextArea fx:id="activityArea"
                              prefHeight="220.0"
                              editable="false"
                              wrapText="true" />

                </VBox>
                <VBox prefWidth="1170.0"
                      prefHeight="220.0"
                      spacing="10.0"
                      style="-fx-background-color: #1f2937;
             -fx-background-radius: 12;
             -fx-padding: 15;">

                    <Label text="🏢 Department Status Overview"
                           style="-fx-text-fill: white;
                  -fx-font-size: 20px;
                  -fx-font-weight: bold;" />

                    <TextArea fx:id="departmentStatusArea"
                              prefHeight="160.0"
                              editable="false"
                              wrapText="true" />

                </VBox>

            </HBox>

        </VBox>

    </children>

</AnchorPane>