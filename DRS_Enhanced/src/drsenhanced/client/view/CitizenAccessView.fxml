<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.CitizenAccessController"
            style="-fx-background-color:#F4F6F8;">

    <top>

        <HBox alignment="CENTER"
              style="-fx-background-color:#1976D2;">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="👤 Citizen Access Portal"
                   style="
                        -fx-text-fill:white;
                        -fx-font-size:28;
                        -fx-font-weight:bold;
                   "/>

        </HBox>

    </top>

    <center>

        <HBox spacing="30">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- LOGIN PANEL -->

            <VBox spacing="15"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:25;
                    -fx-background-radius:10;
                  ">

                <Label text="Citizen Login"
                       style="
                            -fx-font-size:24;
                            -fx-font-weight:bold;
                       "/>

                <TextField fx:id="usernameField"
                           promptText="Username"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"/>

                <Button text="LOGIN"
                        prefHeight="45"
                        onAction="#handleLogin"
                        style="
                            -fx-background-color:#1976D2;
                            -fx-text-fill:white;
                            -fx-font-weight:bold;
                        "/>

                <Label text="Don't have an account?"
                       style="-fx-font-weight:bold;"/>

                <Button text="CREATE ACCOUNT"
                        prefHeight="45"
                        onAction="#handleCreateAccount"
                        style="
                            -fx-background-color:#2E7D32;
                            -fx-text-fill:white;
                            -fx-font-weight:bold;
                        "/>

                <Label text="──────── OR ────────"
                       style="-fx-font-size:16;"/>

                <Button text="🚨 REPORT DISASTER NOW"
                        prefHeight="60"
                        onAction="#handleReportDisaster"
                        style="
                            -fx-background-color:#D32F2F;
                            -fx-text-fill:white;
                            -fx-font-size:18;
                            -fx-font-weight:bold;
                            -fx-background-radius:25;
                            -fx-cursor:hand;
                        "/>

            </VBox>

            <!-- ALERTS PANEL -->

            <VBox spacing="15"
                  prefWidth="500"
                  style="
                    -fx-background-color:white;
                    -fx-padding:25;
                    -fx-background-radius:10;
                  ">

                <Label text="📢 Melbourne Live Alerts"
                       style="
                            -fx-font-size:24;
                            -fx-font-weight:bold;
                       "/>

                <ListView fx:id="alertsList"
                          prefHeight="250"/>

                <Label text="🛡 Safety Reminder"
                       style="
                            -fx-font-size:20;
                            -fx-font-weight:bold;
                       "/>

                <Label text="Stay informed through official Victorian emergency channels."/>

                <Label text="Call Triple Zero (000) for life-threatening emergencies."/>

            </VBox>

        </HBox>

    </center>

    <bottom>

        <HBox alignment="CENTER_LEFT">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Button text="⬅ Back"
                    onAction="#handleBack"/>

        </HBox>

    </bottom>

</BorderPane>