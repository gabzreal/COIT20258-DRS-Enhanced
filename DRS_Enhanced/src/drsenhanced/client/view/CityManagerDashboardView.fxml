<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drsenhanced.client.controller.CityManagerDashboardController"
            prefWidth="1400"
            prefHeight="850"
            style="-fx-background-color:#F4F6F8;">

    <!-- HEADER -->

    <top>

        <VBox>

            <HBox alignment="CENTER_LEFT"
                  prefHeight="55"
                  style="-fx-background-color:#D32F2F;">

                

                <Label text="🎯 Melbourne Emergency Command Centre"
                       style="
                -fx-text-fill:white;
                -fx-font-size:22;
                -fx-font-weight:bold;
           "/>

                
            </HBox>

        </VBox>

    </top>

    <!-- CENTER -->

    <center>

        <VBox spacing="15">

            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- SUBTITLE -->

            <HBox spacing="20"
                  alignment="CENTER_LEFT"
                  style="
            -fx-background-color:white;
            -fx-background-radius:15;
            -fx-border-radius:15;
            -fx-border-color:#E0E0E0;
            -fx-padding:12;
      ">

                <!-- Left Icon -->

                <Label text="🛡"
                       style="
                -fx-font-size:25;
                -fx-text-fill:#D32F2F;
           "/>

                <!-- Title + Subtitle -->

                <VBox spacing="5">

                    <Label text="Melbourne Emergency Operations Overview"
                           style="
                    -fx-font-size:18;
                    -fx-font-weight:bold;
                    -fx-text-fill:#1F2937;
               "/>

                    <Label text="Live incident monitoring • Resource allocation • Multi-agency coordination"
                           style="
                    -fx-font-size:10;
                    -fx-text-fill:#6B7280;
               "/>

                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Back Button -->

                <HBox spacing="10">

                    <Button text="⬅ Back"
                            onAction="#handleBack"
                            prefWidth="110"
                            prefHeight="42"
                            style="
                -fx-background-color:#757575;
                -fx-text-fill:white;
                -fx-font-size:15;
                -fx-font-weight:bold;
                -fx-background-radius:10;
            "/>

                    <Button text="🚪 Logout"
                            onAction="#handleLogout"
                            prefWidth="110"
                            prefHeight="42"
                            style="
                -fx-background-color:#D32F2F;
                -fx-text-fill:white;
                -fx-font-size:15;
                -fx-font-weight:bold;
                -fx-background-radius:10;
            "/>

                </HBox>

            </HBox>

            <!-- STATS -->

            <HBox spacing="20">

                <VBox prefWidth="160"
                      style="-fx-background-color:white;
                 -fx-padding:12;
                 -fx-background-radius:12;
                 -fx-border-radius:12;
                 -fx-border-color:#E0E0E0;">

                    <Label text="ACTIVE INCIDENTS"
                           style="-fx-font-weight:bold;"/>

                    <Label text="12"
                           style="-fx-font-size:25;
                      -fx-font-weight:bold;
                      -fx-text-fill:#C62828;"/>
                </VBox>

                <VBox prefWidth="160"
                      style="-fx-background-color:white;
                 -fx-padding:12;
                 -fx-background-radius:12;
                 -fx-border-radius:12;
                 -fx-border-color:#E0E0E0;">

                    <Label text="CRITICAL"
                           style="-fx-font-weight:bold;"/>

                    <Label text="3"
                           style="-fx-font-size:25;
                      -fx-font-weight:bold;
                      -fx-text-fill:#E65100;"/>
                </VBox>

                <VBox prefWidth="160"
                      style="-fx-background-color:white;
                 -fx-padding:12;
                 -fx-background-radius:12;
                 -fx-border-radius:12;
                 -fx-border-color:#E0E0E0;">

                    <Label text="UNITS DEPLOYED"
                           style="-fx-font-weight:bold;"/>

                    <Label text="18"
                           style="-fx-font-size:25;
                      -fx-font-weight:bold;
                      -fx-text-fill:#2E7D32;"/>
                </VBox>

                <VBox prefWidth="160"
                      style="-fx-background-color:white;
                 -fx-padding:12;
                 -fx-background-radius:12;
                 -fx-border-radius:12;
                 -fx-border-color:#E0E0E0;">

                    <Label text="AVAILABLE SHELTERS"
                           style="-fx-font-weight:bold;"/>

                    <Label text="14"
                           style="-fx-font-size:25;
                      -fx-font-weight:bold;
                      -fx-text-fill:#1976D2;"/>
                </VBox>

            </HBox>

            <!-- OPERATIONS DASHBOARD -->

            <HBox spacing="20">

                <!-- INCIDENT QUEUE -->

                <VBox spacing="10"
                      prefWidth="750"
                      style="
                -fx-background-color:white;
                -fx-padding:20;
                -fx-background-radius:12;
                -fx-border-radius:12;
                -fx-border-color:#E0E0E0;
          ">

                    <Label text="🚨 Active Incident Queue"
                           style="
                    -fx-font-size:20;
                    -fx-font-weight:bold;
               "/>

                    <ListView fx:id="incidentList"
                              prefHeight="450"/>

                    <Button text="🔍 Open Selected Incident"
                            onAction="#handleOpenIncident"
                            prefWidth="250"
                            prefHeight="50"
                            style="
                    -fx-background-color:#1976D2;
                    -fx-text-fill:white;
                    -fx-font-size:18;
                    -fx-font-weight:bold;
                    -fx-background-radius:10;
                "/>

                </VBox>

                <!-- RIGHT SIDE PANELS -->

               

                <HBox spacing="15">

                    <!-- COLUMN 1 -->

                    <VBox spacing="15" prefWidth="280">

                        <!-- DEPARTMENT -->

                        <VBox spacing="10"
                              style="
            -fx-background-color:white;
            -fx-padding:20;
            -fx-background-radius:12;
            -fx-border-radius:12;
            -fx-border-color:#E0E0E0;">

                            <Label text="🚓 Department Status"
                                   style="-fx-font-size:18; -fx-font-weight:bold;"/>

                            <Label text="🚒 Fire Services - Available"/>
                            <Label text="🚑 Ambulance Victoria - Busy"/>
                            <Label text="👮 Victoria Police - Available"/>
                            <Label text="🌊 SES Victoria - Available"/>

                        </VBox>

                        <!-- SHELTER -->

                        <VBox spacing="10"
                              style="
            -fx-background-color:white;
            -fx-padding:20;
            -fx-background-radius:12;
            -fx-border-radius:12;
            -fx-border-color:#E0E0E0;">

                            <Label text="🏠 Shelter Capacity"
                                   style="-fx-font-size:18; -fx-font-weight:bold;"/>

                            <Label text="Town Hall Shelter : 120 / 200"/>
                            <Label text="Docklands Shelter : 80 / 150"/>
                            <Label text="Carlton Hall : 60 / 100"/>

                        </VBox>

                        <!-- WEATHER -->

                        <VBox spacing="10"
                              style="
            -fx-background-color:#FFF8E1;
            -fx-padding:20;
            -fx-background-radius:12;
            -fx-border-radius:12;
            -fx-border-color:#FFE082;">

                            <Label text="🌦 Weather &amp; Risk Forecast"
                                   style="-fx-font-size:18; -fx-font-weight:bold;"/>

                            <Label text="Heavy Rain Expected: 4:00 PM"/>
                            <Label text="Flood Risk: Medium"/>
                            <Label text="Wind Speed: 45 km/h"/>
                            <Label text="Temperature: 11°C"/>

                        </VBox>

                    </VBox>

                    <!-- COLUMN 2 -->

                    <VBox spacing="15" prefWidth="280">

                        <VBox spacing="10"
                              style="
        -fx-background-color:white;
        -fx-padding:20;
        -fx-background-radius:12;
        -fx-border-radius:12;
        -fx-border-color:#E0E0E0;">

                            <Label text="📝 Recent Response Activity"
                                   style="-fx-font-size:18; -fx-font-weight:bold;"/>

                            <ListView fx:id="responseLogList"
                                      prefHeight="450"/>

                        </VBox>

                    </VBox>

                </HBox> 
            </HBox>


            <VBox spacing="5"
                  style="
            -fx-background-color:white;
            -fx-background-radius:10;
            -fx-border-color:#D9D9D9;
            -fx-border-radius:10;
            -fx-padding:8;
      ">

                <Label text="⚙ Resource Capacity Monitor"
                       style="
                -fx-font-size:15;
                -fx-font-weight:bold;
                -fx-text-fill:#2D3436;
           "/>

                <HBox spacing="15">

                    <VBox spacing="8">

                        <Label text="🚒 Fire Services"/>

                        <ProgressBar progress="0.80"
                                     prefWidth="150"/>

                        <Label text="80% Capacity Available"
                               style="-fx-text-fill:#2E7D32;"/>

                    </VBox>

                    <VBox spacing="8">

                        <Label text="🚑 Ambulance Services"/>

                        <ProgressBar progress="0.90"
                                     prefWidth="150"/>

                        <Label text="90% Capacity Available"
                               style="-fx-text-fill:#2E7D32;"/>

                    </VBox>

                    <VBox spacing="8">

                        <Label text="👮 Victoria Police"/>

                        <ProgressBar progress="0.65"
                                     prefWidth="150"/>

                        <Label text="65% Capacity Available"
                               style="-fx-text-fill:#F57C00;"/>

                    </VBox>

                    <VBox spacing="8">

                        <Label text="🏠 Emergency Shelters"/>

                        <ProgressBar progress="0.45"
                                     prefWidth="220"/>

                        <Label text="45% Capacity Available"
                               style="-fx-text-fill:#D32F2F;"/>

                    </VBox>

                </HBox>

                <Separator/>

                <HBox spacing="8">

                    <Label text="System Status:"
                           style="
                    -fx-font-size:15;
                    -fx-font-weight:bold;
               "/>

                    <Label text="🟠 HIGH LOAD"
                           style="
                    -fx-font-size:15;
                    -fx-font-weight:bold;
                    -fx-text-fill:#F57C00;
               "/>

                </HBox>

            </VBox>

            

        </VBox>

    </center>

</BorderPane>